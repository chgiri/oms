# Copy this file to .env (which is already gitignored) and fill in real
# values before running `docker compose up`. Required vars have no default
# in docker-compose.yml / application.properties and the app/postgres will
# fail to start without them.

# --- Environment profile ---
# One of: dev, test, uat, prod (see src/main/resources/application-{profile}.properties).
# Controls logging verbosity, Swagger UI availability, and whether the throwaway
# JWT/admin/CORS defaults are allowed to be used. Defaults to dev if unset.
# The prod profile requires JWT_PRIVATE_KEY, JWT_PUBLIC_KEY, DEFAULT_ADMIN_PASSWORD
# and CORS_ALLOWED_ORIGINS to all be set explicitly ? it will not start without them.
SPRING_PROFILES_ACTIVE=dev

# --- Postgres (required) ---
DB_NAME=oms
DB_USERNAME=oms_user
DB_PASSWORD=changeme

# --- Redis ---
# For local also set some temp password
REDIS_PASSWORD=devpassword123

# --- JWT (required) ---
# Must be Base64-encoded and decode to at least 32 bytes (HS256 requirement).
# Generate one with: openssl rand -base64 32
JWT_SECRET=changeme-generate-a-real-32-byte-base64-secret
JWT_EXPIRATION_MS=86400000

# --- Default admin account (seeded on first startup if no users exist) ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme
