# Copy this file to .env (which is already gitignored) and fill in real
# values before running `docker compose up`. Required vars have no default
# in docker-compose.yml / application.properties and the app/postgres will
# fail to start without them.

# --- Postgres (required) ---
DB_NAME=oms
DB_USERNAME=oms_user
DB_PASSWORD=changeme

# --- Redis ---
# Leave blank only for throwaway local dev; set a real password for anything
# that isn't strictly local-only.
REDIS_PASSWORD=

# --- JWT (required) ---
# Must be Base64-encoded and decode to at least 32 bytes (HS256 requirement).
# Generate one with: openssl rand -base64 32
JWT_SECRET=changeme-generate-a-real-32-byte-base64-secret
JWT_EXPIRATION_MS=86400000

# --- Default admin account (seeded on first startup if no users exist) ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme
